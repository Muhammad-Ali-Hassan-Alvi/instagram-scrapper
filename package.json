{
  "name": "instagram-scrapper",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "node scripts/dev-local.mjs",
    "dev:clean": "node scripts/clean-dev.mjs",
    "dev:fresh": "node scripts/clean-dev.mjs && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "scrape:instagram": "tsx --tsconfig tsconfig.json scripts/scrape-instagram.ts",
    "scrape:tiktok": "tsx --tsconfig tsconfig.json scripts/scrape-tiktok.ts",
    "instagram:login": "tsx --tsconfig tsconfig.json scripts/instagram-login-once.ts",
    "tiktok:login": "tsx --tsconfig tsconfig.json scripts/tiktok-login-once.ts",
    "tiktok:import-session": "tsx --tsconfig tsconfig.json scripts/import-tiktok-session.ts",
    "tiktok:import-apify": "tsx --tsconfig tsconfig.json scripts/import-apify-tiktok.ts",
    "tiktok:import-ttcs": "tsx --tsconfig tsconfig.json scripts/import-ttcs-tiktok.ts",
    "tiktok:ttcs:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-ttcs.ps1",
    "tiktok:ttcs:discover": "tsx --tsconfig tsconfig.json scripts/tiktok-content-scraper/discover-videos.ts",
    "scrape:tiktok:ttcs": "tsx --tsconfig tsconfig.json scripts/scrape-tiktok-ttcs.ts",
    "cron": "tsx --tsconfig tsconfig.json scripts/cron-worker.ts",
    "cron:once": "tsx --tsconfig tsconfig.json scripts/cron-once.ts",
    "data:status": "tsx --tsconfig tsconfig.json scripts/check-data-status.ts",
    "export:all": "tsx --tsconfig tsconfig.json scripts/export-all.ts",
    "sync:session-to-ec2": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/sync-session-to-ec2.ps1 -Ec2Ip 13.48.105.194",
    "deploy:ec2": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/deploy-to-ec2.ps1 -Ec2Ip 13.48.105.194"
  },
  "dependencies": {
    "apify-client": "^2.23.4",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "mongodb": "^7.4.0",
    "mongoose": "^9.7.3",
    "next": "^15.5.19",
    "node-cron": "^4.5.0",
    "pdfkit": "^0.19.1",
    "playwright": "^1.61.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.5.19",
    "prettier": "^3.9.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
